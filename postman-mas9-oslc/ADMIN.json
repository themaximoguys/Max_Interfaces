    {
      "name": "App XML Deployment (NOT AVAILABLE via API Key)",
      "item": [
        {
          "name": "NOTE - XML Import requires session auth",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              },
              {
                "key": "Cookie",
                "value": "JSESSIONID=YOUR_SESSION_ID"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/xmlimport",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "xmlimport"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<!-- XML Import requires session-based auth (not API key) -->\n<!-- Use browser login or maxauth header with base64 credentials -->\n<maximoIn>\n  <!-- Your application XML here -->\n</maximoIn>",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            },
            "description": "WARNING: XML Import/Export for Application Designer XML is NOT available via API key authentication in MAS 9. It requires session-based authentication (JSESSIONID cookie or maxauth header). Use the Maximo UI or a session-authenticated script for app XML deployment."
          }
        }
      ],
      "description": "Application XML import/export requires session authentication. These endpoints are provided as reference only."
    }
  ]
