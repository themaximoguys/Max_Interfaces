{
  "info": {
    "name": "Maximo MAS 9 OSLC - Admin & Deployment",
    "description": "MAS 9 Administration, Script Deployment, and Script Execution APIs.\nUse 'MAS9-Demo' environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "apikey",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{apikey}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://your-instance.maximo.com/maximo"
    }
  ],
  "item": [
    {
      "name": "Script Execution",
      "item": [
        {
          "name": "Execute Automation Script",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/script/:scriptName",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "script",
                ":scriptName"
              ],
              "variable": [
                {
                  "key": "scriptName",
                  "value": "YOUR_SCRIPT_NAME",
                  "description": "Name of the automation script to execute"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"param1\": \"value1\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Execute an automation script by name. Pass input parameters as JSON body."
          }
        },
        {
          "name": "Execute Script with Response",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/script/:scriptName",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "script",
                ":scriptName"
              ],
              "variable": [
                {
                  "key": "scriptName",
                  "value": "YOUR_SCRIPT_NAME",
                  "description": "Name of the automation script to execute"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Execute an automation script and receive JSON response with output variables."
          }
        }
      ]
    },
    {
      "name": "Script Deployment (CI/CD)",
      "item": [
        {
          "name": "Deploy Script - Create New",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/os/mxapiautoscript",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "os",
                "mxapiautoscript"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"autoscript\": \"MY_CUSTOM_SCRIPT\",\n  \"description\": \"My custom automation script\",\n  \"scriptlanguage\": \"jython\",\n  \"status\": \"Draft\",\n  \"active\": true,\n  \"loglevel\": \"ERROR\",\n  \"source\": \"# Your Jython script code here\\nprint 'Hello from Maximo'\",\n  \"autoscriptvars\": [\n    {\n      \"varname\": \"myvar\",\n      \"varbindingtype\": \"LITERAL\",\n      \"vartype\": \"IN\",\n      \"literaldatatype\": \"ALN\"\n    }\n  ],\n  \"scriptlaunchpoint\": [\n    {\n      \"launchpointname\": \"MY_SCRIPT_LP\",\n      \"launchpointtype\": \"OBJECT\",\n      \"objectname\": \"WORKORDER\",\n      \"eventtype\": \"0\",\n      \"active\": true\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Create a new automation script with source code, variables, and launch point in a single POST."
          }
        },
        {
          "name": "Deploy Script - Update Source Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-method-override",
                "value": "PATCH"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/os/mxapiautoscript/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "os",
                "mxapiautoscript",
                ":id"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"# Updated script source\\nprint 'Updated version'\",\n  \"status\": \"Active\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Update an existing automation script's source code and status. Use the script's ID from a GET request."
          }
        },
        {
          "name": "Deploy Script - Get Full Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/os/mxapiautoscript?oslc.select=autoscript,description,source,status,active,scriptlanguage,loglevel,autoscriptvars,scriptlaunchpoint&oslc.where=autoscript=%22MY_CUSTOM_SCRIPT%22&lean=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "os",
                "mxapiautoscript"
              ],
              "query": [
                {
                  "key": "oslc.select",
                  "value": "autoscript,description,source,status,active,scriptlanguage,loglevel,autoscriptvars,scriptlaunchpoint"
                },
                {
                  "key": "oslc.where",
                  "value": "autoscript=\"MY_CUSTOM_SCRIPT\""
                },
                {
                  "key": "lean",
                  "value": "1"
                }
              ]
            },
            "description": "Get full automation script details including source code, variables, and launch points."
          }
        },
        {
          "name": "Deploy Script - List All Scripts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/os/mxapiautoscript?oslc.select=autoscript,description,status,active,scriptlanguage&oslc.pageSize=50&lean=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "os",
                "mxapiautoscript"
              ],
              "query": [
                {
                  "key": "oslc.select",
                  "value": "autoscript,description,status,active,scriptlanguage"
                },
                {
                  "key": "oslc.pageSize",
                  "value": "50"
                },
                {
                  "key": "lean",
                  "value": "1"
                }
              ]
            },
            "description": "List all automation scripts with their status."
          }
        },
        {
          "name": "Deploy Script - Delete Script",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/oslc/os/mxapiautoscript/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "oslc",
                "os",
                "mxapiautoscript",
                ":id"
              ]
            },
            "description": "Delete an automation script by ID."
          }
        }
      ]
    },
